# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://your-la1-domain.com

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/la1_poker

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Wallet API ────────────────────────────────────────────────────────────────
WALLET_URL=https://la1-backend-production.up.railway.app
SECRET=your-hmac-secret-key-here

# ── Dynamic Game Parameters (override DB defaults) ────────────────────────────
# These env vars are used as FALLBACKS when DB is unavailable.
# To change live values, update the system_configs table instead.

RAKE_PERCENT=0.05
RAKE_CAP=10
RAKE_NO_RAKE_THRESHOLD=10

BOT_ENABLED=true
BOT_THINK_MIN=800
BOT_THINK_MAX=3000

TURN_TIMEOUT_SECONDS=30
TURN_WARNING_SECONDS=10

MM_MIN_PLAYERS=2
MM_WAIT_SECONDS=15
