# Telegram Bot Token
TG_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL (optional, for custom endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Backend API URL
BACKEND_URL=https://la1-backend-production.up.railway.app

# Admin Telegram IDs (comma-separated, for escalation notifications)
# ADMIN_TG_IDS=123456789,987654321

# 客服工作群組 ID（負數，例如 -1003427212959）
# 玩家轉人工時，Bot 會將訊息轉發到此群組
# 客服在群組中 reply 轉發的訊息時，Bot 自動轉發回玩家
SUPPORT_GROUP_ID=-1003427212959
